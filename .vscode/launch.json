{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Windows (Impeller)",
      "request": "launch",
      "type": "dart",
      "deviceId": "windows",
      // flutter_scene renders through Impeller + Flutter GPU; neither is
      // default on Windows desktop yet, so both must be enabled explicitly.
      "args": ["--enable-impeller", "--enable-flutter-gpu"]
    },
    {
      "name": "Windows (software renderer only)",
      "request": "launch",
      "type": "dart",
      "deviceId": "windows"
    }
  ]
}
